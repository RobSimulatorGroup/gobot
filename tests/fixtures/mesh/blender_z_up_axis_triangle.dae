<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_geometries>
    <geometry id="axis_triangle" name="axis_triangle">
      <mesh>
        <source id="axis_triangle-positions">
          <float_array id="axis_triangle-positions-array" count="9">0 0 0 0 -2 0 1 -2 0</float_array>
          <technique_common>
            <accessor source="#axis_triangle-positions-array" count="3" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="axis_triangle-vertices">
          <input semantic="POSITION" source="#axis_triangle-positions"/>
        </vertices>
        <triangles count="1">
          <input semantic="VERTEX" source="#axis_triangle-vertices" offset="0"/>
          <p>0 1 2</p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="axis_triangle_node" name="axis_triangle_node">
        <matrix sid="transform">1 0 0 0 0 -1.62921e-7 -1 0 0 1 -1.62921e-7 0 0 0 0 1</matrix>
        <instance_geometry url="#axis_triangle"/>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
